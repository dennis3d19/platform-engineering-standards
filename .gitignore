# Platform Engineering Standards - .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
.pytest_cache/
.coverage
htmlcov/
.tox/
venv/
.venv/
env/
*.egg

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/

# Terraform
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.backup
*.tfstate.*.backup
.terraform.tfstate.lock.info
override.tf
override.tf.json
*_override.tf
*_override.tf.json
crash.log
crash.*.log
*.tfvars
!examples/**/*.tfvars.example
backend.hcl

# Helm
charts/
Chart.lock

# Secrets and credentials
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
id_rsa
id_dsa
id_ecdsa
id_ed25519
*.secret
.env
.env.*
!.env.example
.secrets.baseline

# Editor directories and files
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Generated files
docs/INDEX.md
/dist/
/tmp/

# pre-commit cache
.pre-commit-cache/

# detect-secrets
.secrets.baseline
